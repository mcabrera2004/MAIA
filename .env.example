# ─── Application ──────────────────────────────────────────────
APP_ENV=development
PROJECT_NAME="Asistente Educativo IA"
VERSION=1.0.0
DEBUG=true
API_V1_STR=/api/v1

# ─── CORS ─────────────────────────────────────────────────────
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:5173,http://localhost:8000"

# ─── Google Gemini ────────────────────────────────────────────
GOOGLE_API_KEY="your_google_api_key_here"
DEFAULT_LLM_MODEL=gemini-2.5-flash
DEFAULT_LLM_TEMPERATURE=0.2
MAX_TOKENS=2000

# ─── Langfuse ─────────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=""
LANGFUSE_SECRET_KEY=""
LANGFUSE_HOST=https://cloud.langfuse.com

# ─── PostgreSQL + pgvector (Docker) ───────────────────────────
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=agentdb
POSTGRES_USER=agentuser
POSTGRES_PASSWORD=agentpass123
POSTGRES_POOL_SIZE=5
POSTGRES_MAX_OVERFLOW=10

# ─── JWT ──────────────────────────────────────────────────────
JWT_SECRET_KEY="generate_a_secure_random_key_for_production"
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_DAYS=30

# ─── RAG / Knowledge Base ─────────────────────────────────────
RAG_EMBEDDING_MODEL=models/gemini-embedding-001
RAG_COLLECTION_NAME=knowledge_documents
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200
RAG_TOP_K=5

# ─── Available Subjects ───────────────────────────────────────
AVAILABLE_SUBJECTS="historia,derecho informatico"

# ─── Long-term Memory (mem0) ──────────────────────────────────
LONG_TERM_MEMORY_MODEL=gemini-2.5-flash
LONG_TERM_MEMORY_EMBEDDER_MODEL=models/gemini-embedding-001
LONG_TERM_MEMORY_COLLECTION_NAME=longterm_memory

# ─── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_DEFAULT="1000 per day,200 per hour"
RATE_LIMIT_CHAT="100 per minute"
RATE_LIMIT_CHAT_STREAM="100 per minute"
RATE_LIMIT_MESSAGES="200 per minute"
RATE_LIMIT_LOGIN="100 per minute"

# ─── Logging ──────────────────────────────────────────────────
LOG_LEVEL=DEBUG
LOG_FORMAT=console
